<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="?attr/colorPrimary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Timeline"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timelineItemCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 项"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/btnJumpToDate"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="跳转到日期"
            android:tint="#FFFFFF"/>
    </LinearLayout>

    <!-- 控制栏 - 时间范围和排序选择 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#F5F5F5"
        android:gravity="center_vertical">

        <!-- 时间范围选择（左侧） -->
        <Spinner
            android:id="@+id/timelineRangeSpinner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minWidth="120dp" />

        <!-- 排序方向选择（右侧） -->
        <Button
            android:id="@+id/timelineSortButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="顺序"
            android:layout_marginStart="16dp"
            android:minWidth="80dp" />
    </LinearLayout>

    <!-- 时间线列表 -->
    <ListView
        android:id="@+id/timelineListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="8dp"
        android:background="#F5F5F5">

        <Button
            android:id="@+id/btnCloseTimeline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关闭"
            android:minWidth="100dp" />
    </LinearLayout>

</LinearLayout>
