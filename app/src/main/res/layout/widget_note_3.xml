<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widgetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NotePlus"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#333333" />

        <Button
            android:id="@+id/widgetConfigButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="配置"
            android:textSize="10sp"
            android:padding="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/widgetRefreshButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="刷新"
            android:textSize="10sp"
            android:padding="4dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/widgetNote1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未设置"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#333333"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/widgetNote2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未设置"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#333333"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/widgetNote3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未设置"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#333333" />

    <TextView
        android:id="@+id/widgetNote4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未设置"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#333333"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widgetNote5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="未设置"
        android:maxLines="2"
        android:ellipsize="end"
        android:textColor="#333333"
        android:layout_marginTop="4dp"
        android:visibility="gone" />
</LinearLayout>
